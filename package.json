{
  "name": "siklusio-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Express API server (Gemini + Supabase admin) for Siklusio. Mobile app lives in mobile-app/.",
  "scripts": {
    "dev": "tsx backend/index.ts",
    "build": "esbuild backend/index.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@supabase/supabase-js": "^2.106.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
