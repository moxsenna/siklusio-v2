# Copy file ini ke .env.local lalu isi nilai-nilainya.
# JANGAN commit .env.local ke git (sudah ada di .gitignore).
# JANGAN taruh kredensial asli di .env.example.

# Gemini AI
GEMINI_API_KEY="your-gemini-api-key"

# App URL (dev)
APP_URL="http://localhost:3000"

# Supabase — ambil dari Dashboard > Settings > API
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-public-key"

# WAJIB DIRAHASIAKAN. Hanya untuk backend (Express).
# Bisa bypass semua RLS, jangan pernah pakai di frontend / commit ke git.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Cloudflare R2 (Avatar Storage) — HANYA untuk backend
# Buat bucket dan API token di https://dash.cloudflare.com > R2 Object Storage
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="siklusio-avatars"
R2_PUBLIC_URL="https://cdn.siklusio.web.id"
