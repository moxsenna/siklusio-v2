{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "siklusio-backend",
  "main": "backend/src/index.ts",
  "compatibility_date": "2026-05-24",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    {
      "pattern": "api.siklusio.web.id",
      "custom_domain": true
    }
  ],
  "vars": {
    "R2_BUCKET_NAME": "siklusio-avatars",
    "R2_PUBLIC_URL": "https://cdn.siklusio.web.id",
    "OPENROUTER_FREE_MODEL": "qwen/qwen3-next-80b-a3b-instruct:free",
    "OPENROUTER_PAID_MODEL": "openai/gpt-5-nano"
  },
  "observability": {
    "enabled": true
  }
}
