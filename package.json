{
  "name": "siklusio-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Hono API server (OpenRouter + Supabase admin) for Siklusio. Mobile app lives in mobile-app/.",
  "scripts": {
    "generate:types": "node scripts/generate-supabase-types.mjs",
    "dev": "wrangler dev backend/src/index.ts --port 3000",
    "dev:backend": "wrangler dev backend/src/index.ts",
    "deploy": "wrangler deploy backend/src/index.ts",
    "deploy:backend": "wrangler deploy backend/src/index.ts",
    "clean": "rm -rf dist",
    "lint": "npm run typecheck:backend",
    "typecheck:backend": "tsc --noEmit",
    "typecheck:mobile": "npm --prefix mobile-app run typecheck",
    "test": "node scripts/run-tests.mjs",
    "check": "npm run typecheck:backend && npm run typecheck:mobile && npm test",
    "db:migrations:list": "supabase migration list --linked",
    "db:push:dry-run": "supabase db push --dry-run",
    "db:types": "npm run generate:types",
    "db:lint": "supabase db lint --linked --schema public --fail-on error",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,yml,yaml,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,yml,yaml,md}\"",
    "format:check:ci": "prettier --check \"backend/**/*.{ts,tsx,js}\" \".github/**/*.{yml,yaml}\" \"scripts/**/*.{mjs,js}\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1054.0",
    "@google/genai": "^1.29.0",
    "@supabase/supabase-js": "^2.106.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "googleapis": "^173.0.0",
    "hono": "^4.12.23",
    "playwright": "^1.60.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "esbuild": "^0.25.0",
    "prettier": "^3.8.3",
    "supabase": "^2.102.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "wrangler": "^4.95.0"
  }
}
