# Copy file ini ke .env.local lalu isi nilai-nilainya.
# JANGAN commit .env.local ke git (sudah ada di .gitignore).
# JANGAN taruh kredensial asli di .env.example.

# OpenRouter AI
OPENROUTER_API_KEY="your-openrouter-api-key"
OPENROUTER_FREE_MODEL="qwen/qwen3-next-80b-a3b-instruct:free"
OPENROUTER_PAID_MODEL="openai/gpt-5-nano"

# App URL (dev)
APP_URL="http://localhost:3000"

# Mobile/web client API URL (wajib untuk production build)
EXPO_PUBLIC_API_BASE_URL="https://api.siklusio.web.id"

# Backend CORS allowlist tambahan, pisahkan dengan koma.
# Domain production Siklusio dan localhost sudah diizinkan oleh default.
ALLOWED_ORIGINS="https://staging.siklusio.web.id"

# Backend rate limit guardrails (opsional; default aman jika kosong)
AI_RATE_LIMIT_MAX="20"
AI_RATE_LIMIT_WINDOW_SECONDS="60"
CHECKOUT_RATE_LIMIT_MAX="10"
CHECKOUT_RATE_LIMIT_WINDOW_SECONDS="300"
WEBHOOK_RATE_LIMIT_MAX="120"
WEBHOOK_RATE_LIMIT_WINDOW_SECONDS="60"

# Mayar payment (backend/Worker secret)
MAYAR_API_KEY="your-mayar-api-key"
MAYAR_WEBHOOK_TOKEN="your-mayar-webhook-callback-token"

# Supabase — ambil dari Dashboard > Settings > API
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-public-key"

# WAJIB DIRAHASIAKAN. Hanya untuk backend (Express).
# Bisa bypass semua RLS, jangan pernah pakai di frontend / commit ke git.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Cloudflare R2 (Avatar Storage) — HANYA untuk backend
# Buat bucket dan API token di https://dash.cloudflare.com > R2 Object Storage
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="siklusio-avatars"
R2_PUBLIC_URL="https://cdn.siklusio.web.id"
