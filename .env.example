# ==============================================================================
# SIKLUSIO V2 - TEMPLATE VARIABEL LINGKUNGAN (.env.example)
# ==============================================================================
#
# Salin file ini menjadi `.env.local` di folder root untuk konfigurasi backend,
# dan salin/buat file `.env` di dalam folder `mobile-app/` untuk konfigurasi klien Expo.
#
# PENTING:
# 1. JANGAN PERNAH menyimpan kredensial asli di dalam file ini.
# 2. JANGAN PERNAH commit `.env.local` atau `mobile-app/.env` asli ke Git.
#
# ==============================================================================

# ------------------------------------------------------------------------------
# 🧠 KONFIGURASI OPENROUTER AI
# ------------------------------------------------------------------------------
# API Key OpenRouter untuk mengakses LLM (disimpan di backend/Worker secret)
OPENROUTER_API_KEY="your-openrouter-api-key"

# Model AI gratis yang digunakan untuk fallback atau fitur ramah biaya
OPENROUTER_FREE_MODEL="qwen/qwen3-next-80b-a3b-instruct:free"

# Model AI berbayar utama untuk analisis siklus dan habit coaching yang presisi
OPENROUTER_PAID_MODEL="openai/gpt-5-nano"

# ------------------------------------------------------------------------------
# 🗄️ KONFIGURASI SUPABASE (DATABASE & AUTH)
# ------------------------------------------------------------------------------
# URL Endpoint proyek Supabase (bisa diakses oleh frontend/Vite/Expo)
VITE_SUPABASE_URL="https://your-project.supabase.co"
EXPO_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"

# Public Anon Key Supabase (aman dipublikasikan ke klien)
VITE_SUPABASE_ANON_KEY="your-anon-public-key"
EXPO_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# SUPABASE SERVICE ROLE KEY (WAJIB DIRAHASIAKAN)
# Hanya untuk backend Workers. Digunakan untuk mem-bypass RLS demi kebutuhan sinkronisasi admin.
# JANGAN PERNAH diekspos ke kode mobile-app/ atau dikomit ke Git!
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ID Proyek Supabase untuk sinkronisasi skema migrasi lokal/remote via CLI
SUPABASE_PROJECT_REF="your-supabase-project-ref"

# ------------------------------------------------------------------------------
# 💳 PAYMENT GATEWAY - INTEGRASI MAYAR
# ------------------------------------------------------------------------------
# API Key Mayar (disimpan di backend/Worker secret)
MAYAR_API_KEY="your-mayar-api-key"

# Token verifikasi untuk memastikan callback webhook benar-benar berasal dari Mayar
MAYAR_WEBHOOK_TOKEN="your-mayar-webhook-callback-token"

# URL dasar aplikasi untuk redirect atau landing page (development)
APP_URL="http://localhost:3000"

# ------------------------------------------------------------------------------
# ☁️ CLOUDFLARE R2 BUCKET (AVATAR STORAGE)
# ------------------------------------------------------------------------------
# ID Akun Cloudflare R2 (hanya untuk backend)
R2_ACCOUNT_ID="your-cloudflare-account-id"

# API Token Key untuk akses bucket R2 (hanya untuk backend)
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"

# Nama bucket penyimpanan file avatar
R2_BUCKET_NAME="siklusio-avatars"

# URL Publik CDN yang mengarah ke bucket R2 (misal untuk menyajikan gambar avatar)
R2_PUBLIC_URL="https://cdn.siklusio.web.id"

# ------------------------------------------------------------------------------
# 🖼️ IMGBB INTEGRATION (MOBILE CUSTOM AVATAR)
# ------------------------------------------------------------------------------
# API Key ImgBB untuk mengunggah avatar kustom langsung dari aplikasi mobile
EXPO_PUBLIC_IMGBB_API_KEY="your-imgbb-api-key"

# ------------------------------------------------------------------------------
# 📈 META CONVERSIONS API (CAPI) & PIXEL
# ------------------------------------------------------------------------------
# ID Meta Pixel untuk tracking konversi di frontend/landing
META_PIXEL_ID="your-meta-pixel-id"

# Access Token Meta Conversions API untuk mengirimkan data konversi server-to-server
META_CAPI_ACCESS_TOKEN="your-meta-capi-access-token"

# Versi Graph API Meta (misalnya: v19.0)
META_GRAPH_API_VERSION="v19.0"

# Kode event uji coba dari Meta Events Manager (untuk mode development/testing)
META_TEST_EVENT_CODE="TEST12345"

# Token rahasia khusus untuk memvalidasi mode uji coba Meta (jika diperlukan)
META_TEST_MODE_SECRET="your-meta-test-mode-secret"

# ------------------------------------------------------------------------------
# 🌐 JALUR KONEKSI API & CORS ALLOWLIST
# ------------------------------------------------------------------------------
# URL Endpoint API Server Backend (wajib didefinisikan di mobile-app/.env)
EXPO_PUBLIC_API_BASE_URL="http://localhost:3000"

# Domain CORS tambahan diizinkan mengakses backend (pisahkan dengan koma)
# Domain localhost dan domain production Siklusio sudah diizinkan secara default.
ALLOWED_ORIGINS="https://staging.siklusio.web.id"

# Mode debug untuk mencatat log payload webhook masuk secara rinci (true/false)
DEBUG_WEBHOOK_LOGS="false"

# ------------------------------------------------------------------------------
# 🚦 RATE LIMITER GUARDRAILS (BACKEND CONTROL)
# ------------------------------------------------------------------------------
# Konfigurasi pembatasan akses API harian/menitan untuk mencegah penyalahgunaan
AI_RATE_LIMIT_MAX="20"
AI_RATE_LIMIT_WINDOW_SECONDS="60"

CHECKOUT_RATE_LIMIT_MAX="10"
CHECKOUT_RATE_LIMIT_WINDOW_SECONDS="300"

WEBHOOK_RATE_LIMIT_MAX="120"
WEBHOOK_RATE_LIMIT_WINDOW_SECONDS="60"

# Mode penanganan pembatasan jika database Redis/Postgres rate limit sedang bermasalah
# Pilihan: "memory" (menyimpan sementara di RAM memory worker) atau "fail_closed" (tutup akses demi keamanan)
RATE_LIMIT_FALLBACK_MODE="memory"

# ------------------------------------------------------------------------------
# 📱 WHATSAPP AUTORESPONDER - INTEGRASI FONNTE
# ------------------------------------------------------------------------------
# API Token Fonnte untuk mengirim pesan WhatsApp (simpan di backend/Worker secret)
FONNTE_TOKEN="your-fonnte-token"

# Kode negara default untuk nomor WhatsApp tujuan (misal 62 untuk Indonesia)
FONNTE_COUNTRY_CODE="62"

# Hanya kirim jika WhatsApp terkoneksi di Fonnte (true/false)
FONNTE_CONNECT_ONLY="true"

